{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "apexphysio/**",
              "apexphysio/marketing/**",
              "components/core/**",
              "components/remedypills/**",
              "ui_kits/nbv-website/**",
              "ui_kits/remedypills-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Poppins))/i]",
        "message": "Font not provided by the design system. Available: Inter, Poppins."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|active|processing|ready|completed|primary)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'active' | 'processing' | 'ready' | 'completed' | 'primary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<BottomNavItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|brand|pill|className|style|children|onClick|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, brand, pill, className, style, children, onClick, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|secondary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'secondary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|default|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'default' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='brand'] > Literal[value!=/^(?:remedypills|nbv)$/]",
        "message": "<Button> brand must be one of 'remedypills' | 'nbv'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|hoverable|className|style|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: brand, hoverable, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='brand'] > Literal[value!=/^(?:remedypills|nbv)$/]",
        "message": "<Card> brand must be one of 'remedypills' | 'nbv'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|style|placeholder|type|value|onChange|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: brand, style, placeholder, type, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='brand'] > Literal[value!=/^(?:remedypills|nbv)$/]",
        "message": "<Input> brand must be one of 'remedypills' | 'nbv'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuickActionTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|tone|onClick|key|ref|className|style|children)$/]",
        "message": "<QuickActionTile> doesn't accept that prop. Declared props: icon, label, tone, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuickActionTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:teal|amber|blue|pink|purple|orange|emerald)$/]",
        "message": "<QuickActionTile> tone must be one of 'teal' | 'amber' | 'blue' | 'pink' | 'purple' | 'orange' | 'emerald'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
